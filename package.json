{
  "name": "finsight",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "start:windows": "npx react-native start --config metro.config.windows.js --port 8081",
    "dev:windows": "powershell -NoProfile -Command \"Start-Process powershell -ArgumentList '-NoExit','-Command','Set-Location ''$PWD''; npm run start:windows'; npm run windows\"",
    "windows": "npx react-native run-windows --no-packager",
    "test:windows": "jest --config jest.config.windows.js"
  },
  "dependencies": {
    "@expo-google-fonts/space-grotesk": "^0.2.3",
    "@react-native-ml-kit/text-recognition": "^2.0.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/stack": "^6.4.1",
    "buffer": "^6.0.3",
    "expo": "^54.0.33",
    "expo-asset": "~12.0.12",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-secure-store": "~15.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-windows": "^0.81.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native-community/cli": "17.0.0",
    "@react-native/metro-config": "^0.81.6",
    "@rnx-kit/jest-preset": "^0.1.17",
    "babel-preset-expo": "~54.0.10"
  },
  "react-native-windows": {
    "init-windows": {
      "name": "finsight",
      "namespace": "finsight",
      "template": "cpp-app"
    }
  }
}
